<mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="600">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="Research with AI on Your Shoulder" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="20" width="400" height="30" as="geometry"/>
    </mxCell>
    <!-- Claude Code CLI -->
    <mxCell id="claude" value="Claude Code CLI" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="300" y="70" width="200" height="40" as="geometry"/>
    </mxCell>
    <!-- Research Partner -->
    <mxCell id="partner" value="/research-partner&#xa;(統括エージェント)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="300" y="140" width="200" height="50" as="geometry"/>
    </mxCell>
    <!-- Arrow from claude to partner -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="claude" target="partner" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Skills row -->
    <mxCell id="survey" value="/survey-*&#xa;論文調査" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="120" y="230" width="100" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="idea" value="/idea-organizer&#xa;整理・図解" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="240" y="230" width="100" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="related" value="/related-work&#xa;先行研究" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="360" y="230" width="100" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="next" value="/next-action&#xa;次のタスク" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="480" y="230" width="100" height="50" as="geometry"/>
    </mxCell>
    <!-- Arrows from partner to skills -->
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="partner" target="survey" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="partner" target="idea" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="partner" target="related" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="partner" target="next" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- MCP Layer -->
    <mxCell id="mcp_label" value="MCP Servers" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="320" y="310" width="100" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="arxiv" value="ArXiv MCP" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="200" y="340" width="100" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="semantic" value="Semantic Scholar" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="340" width="110" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="drawio" value="draw.io" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="450" y="340" width="80" height="40" as="geometry"/>
    </mxCell>
    <!-- Arrows from skills to MCPs -->
    <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#999999;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="survey" target="arxiv" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#999999;dashed=1;exitX=0.75;exitY=1;entryX=0.25;entryY=0;" edge="1" source="idea" target="semantic" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#999999;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="related" target="drawio" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Content Layer -->
    <mxCell id="content_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="150" y="420" width="420" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="content_label" value="content/" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="160" y="425" width="80" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="themes" value="themes/&#xa;研究テーマ" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="170" y="450" width="80" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="papers" value="papers/&#xa;論文ノート" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="270" y="450" width="80" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="daily" value="daily/&#xa;日次メモ" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="370" y="450" width="80" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="generated" value="generated/&#xa;AI生成" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="470" y="450" width="80" height="40" as="geometry"/>
    </mxCell>
    <!-- Arrow from MCPs to content -->
    <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="arxiv" target="content_box" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
