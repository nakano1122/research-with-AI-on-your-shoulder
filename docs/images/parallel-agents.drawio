<mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="400">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="並列エージェントによる効率化" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="250" y="10" width="300" height="30" as="geometry"/>
    </mxCell>
    <!-- Traditional Method -->
    <mxCell id="trad_label" value="従来の方法" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="100" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="trad_user" value="User" style="ellipse;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="40" y="90" width="60" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="trad_s1" value="検索1" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="130" y="95" width="60" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="trad_s2" value="検索2" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="220" y="95" width="60" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="trad_s3" value="検索3" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="310" y="95" width="60" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="trad_s4" value="検索4" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="400" y="95" width="60" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="trad_merge" value="統合" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="490" y="95" width="50" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="trad_result" value="結果" style="ellipse;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="570" y="90" width="60" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="trad_time" value="30分" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#b85450;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="660" y="95" width="50" height="30" as="geometry"/>
    </mxCell>
    <!-- Arrows for traditional -->
    <mxCell id="te1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="trad_user" target="trad_s1" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="te2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="trad_s1" target="trad_s2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="te3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="trad_s2" target="trad_s3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="te4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="trad_s3" target="trad_s4" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="te5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="trad_s4" target="trad_merge" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="te6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;" edge="1" source="trad_merge" target="trad_result" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Divider -->
    <mxCell id="divider" value="" style="line;strokeWidth=2;strokeColor=#cccccc;" vertex="1" parent="1">
      <mxGeometry x="40" y="160" width="680" height="10" as="geometry"/>
    </mxCell>
    <!-- Parallel Method -->
    <mxCell id="para_label" value="このプロジェクト" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="40" y="180" width="120" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="para_user" value="User" style="ellipse;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="40" y="230" width="60" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="para_a1" value="Agent 1&#xa;arXiv検索" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="160" y="200" width="80" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="para_a2" value="Agent 2&#xa;関連分野" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="160" y="250" width="80" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="para_a3" value="Agent 3&#xa;引用網" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="160" y="300" width="80" height="40" as="geometry"/>
    </mxCell>
    <!-- Parallel indicator -->
    <mxCell id="para_brace" value="" style="shape=curlyBracket;whiteSpace=wrap;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;flipH=1;size=0.5;" vertex="1" parent="1">
      <mxGeometry x="250" y="200" width="20" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="para_text" value="並列実行" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="270" y="255" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="para_merge" value="統合" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="350" y="240" width="50" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="para_result" value="結果" style="ellipse;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="430" y="235" width="60" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="para_time" value="10分" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontColor=#82b366;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="510" y="240" width="50" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="speedup" value="3x faster" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#82b366;fontStyle=3;" vertex="1" parent="1">
      <mxGeometry x="570" y="240" width="70" height="30" as="geometry"/>
    </mxCell>
    <!-- Arrows for parallel -->
    <mxCell id="pe1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;exitX=1;exitY=0.25;entryX=0;entryY=0.5;" edge="1" source="para_user" target="para_a1" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="pe2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="para_user" target="para_a2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="pe3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;exitX=1;exitY=0.75;entryX=0;entryY=0.5;" edge="1" source="para_user" target="para_a3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="pe4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;exitX=1;exitY=0.5;entryX=0;entryY=0.25;" edge="1" source="para_a1" target="para_merge" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="pe5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="para_a2" target="para_merge" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="pe6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;exitX=1;exitY=0.5;entryX=0;entryY=0.75;" edge="1" source="para_a3" target="para_merge" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="pe7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="para_merge" target="para_result" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
