{
  "$schema": "https://json-schema.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(./framework/scripts/*)",
      "WebSearch"
    ],
    "deny": ["Bash(rm -rf:*)"]
  },
  "mcpServers": {
    "arxiv": {
      "command": "uvx",
      "args": ["arxiv-mcp-server"]
    },
    "academic-search": {
      "command": "npx",
      "args": ["-y", "academic-search-mcp-server"]
    }
  }
}
