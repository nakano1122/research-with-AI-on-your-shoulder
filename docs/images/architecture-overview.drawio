<mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="580">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="Research with AI on Your Shoulder" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="15" width="400" height="30" as="geometry"/>
    </mxCell>

    <!-- Claude Code -->
    <mxCell id="claude" value="Claude Code" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="250" y="60" width="200" height="40" as="geometry"/>
    </mxCell>

    <!-- Research Partner -->
    <mxCell id="partner" value="/research-partner&#xa;(統括エージェント)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="250" y="130" width="200" height="50" as="geometry"/>
    </mxCell>

    <!-- Arrow: Claude to Partner -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;strokeWidth=2;endArrow=classic;" edge="1" source="claude" target="partner" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Skills Container -->
    <mxCell id="skills_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;opacity=30;" vertex="1" parent="1">
      <mxGeometry x="60" y="210" width="390" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="skills_label" value="研究支援スキル" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="70" y="215" width="100" height="20" as="geometry"/>
    </mxCell>

    <!-- Skills Row 1 -->
    <mxCell id="survey" value="/survey-*&#xa;論文調査" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="80" y="240" width="85" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="paper" value="/paper-reader&#xa;論文解説" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="180" y="240" width="85" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="related" value="/related-work&#xa;関連研究" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="280" y="240" width="85" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="pdf" value="/pdf-to-md&#xa;PDF変換" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="380" y="240" width="75" height="40" as="geometry"/>
    </mxCell>

    <!-- Skills Row 2 -->
    <mxCell id="idea" value="/idea-organizer&#xa;整理・図解" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="130" y="295" width="95" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="next" value="/next-action&#xa;次のタスク" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="240" y="295" width="90" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="codextask" value="/codex-task" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="345" y="295" width="90" height="40" as="geometry"/>
    </mxCell>

    <!-- Arrow: Partner to Skills Box -->
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=2;endArrow=classic;" edge="1" source="partner" target="skills_box" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Codex CLI (separate branch) -->
    <mxCell id="codexcli" value="Codex CLI&#xa;(並列ワーカー)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="510" y="210" width="120" height="50" as="geometry"/>
    </mxCell>

    <!-- Arrow: Partner to Codex CLI -->
    <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;dashed=1;" edge="1" source="partner" target="codexcli" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="480" y="155"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="codex_label" value="高速・並列処理" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=9;fontStyle=2;fontColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="520" y="260" width="90" height="15" as="geometry"/>
    </mxCell>

    <!-- MCP Layer -->
    <mxCell id="mcp_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;opacity=30;" vertex="1" parent="1">
      <mxGeometry x="140" y="370" width="250" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="mcp_label" value="MCP Servers" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="150" y="375" width="90" height="15" as="geometry"/>
    </mxCell>
    <mxCell id="arxiv" value="arxiv" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="160" y="395" width="70" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="academic" value="academic-search" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="250" y="395" width="110" height="30" as="geometry"/>
    </mxCell>

    <!-- Arrow: Skills to MCP -->
    <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;dashed=1;endArrow=classic;" edge="1" source="skills_box" target="mcp_box" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Content Layer -->
    <mxCell id="content_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;opacity=30;" vertex="1" parent="1">
      <mxGeometry x="140" y="460" width="320" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="content_label" value="content/" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="150" y="465" width="60" height="15" as="geometry"/>
    </mxCell>
    <mxCell id="themes" value="themes/" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="160" y="485" width="70" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="papers" value="papers/" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="250" y="485" width="70" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="daily" value="daily/" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="340" y="485" width="70" height="35" as="geometry"/>
    </mxCell>

    <!-- Arrow: MCP to Content -->
    <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;endArrow=classic;" edge="1" source="mcp_box" target="content_box" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
