{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(./framework/scripts/*)",
      "WebSearch"
    ],
    "deny": ["Bash(rm -rf:*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./framework/scripts/lint-format.sh",
            "timeout": 30,
            "statusMessage": "Running lint & format..."
          }
        ]
      }
    ]
  }
}
